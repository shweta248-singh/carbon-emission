# API Configuration
PORT=5000
NODE_ENV=production

# Database
MONGODB_URI=mongodb://localhost:27017/carbontrace

# Security (Required)
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_64_chars_at_least
JWT_EXPIRE=7d

# Cookie Secret for signed cookies
COOKIE_SECRET=your_cookie_signing_secret

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Third-party APIs
ORS_API_KEY=your_openrouteservice_api_key
OPENROUTER_API_KEY=your_openrouter_chatbot_api_key

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@carbontrace.com
FROM_NAME=CarbonTrace
